{
  "manifest_version": 3,
  "name": "Search Cashback Injector",
  "version": "0.1.0",
  "description": "Detects supported merchants on Google Search results and surfaces inline cashback offers.",
  "permissions": ["storage"],
  "host_permissions": ["https://www.google.com/*"],
  "background": {
    "service_worker": "background/index.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://www.google.com/search*"],
      "js": ["content/index.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
